{
  "tasks": {
    "dev": "deno run --watch --allow-net mod.ts",
    "start": "deno run --allow-net mod.ts",
    "smoke": "deno run --allow-net mod.ts --timeout 3000",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "test": "deno test --allow-read",
    "check": "deno check mod.ts src/**/*.ts"
  },
  "compilerOptions": {
    "strict": true
  },
  "fmt": {
    "lineWidth": 100,
    "singleQuote": false,
    "indentWidth": 2,
    "include": ["mod.ts", "src/"]
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "imports": {
    "@cfworker/json-schema": "npm:@cfworker/json-schema@^2.0.1"
  }
}
