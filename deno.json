{
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-read --allow-env mod.tsx --dev",
    "start": "deno run --allow-net --allow-read --allow-env mod.tsx",
    "smoke": "deno run --allow-net --allow-read --allow-env mod.tsx --timeout 3000",
    "fmt": "deno fmt",
    "lint": "deno lint --fix",
    "test": "deno test --allow-read",
    "check": "deno check mod.tsx src/graph/**/*.ts src/ui/App.tsx src/ui/StoriesShell.tsx src/ui/workspace.ts",
    "check-ui": "deno check --config deno.client.json src/ui/client.tsx src/ui/stories/main.tsx",
    "build": "deno run --allow-read --allow-write --allow-net --allow-env build.ts"
  },
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@hono/hono/jsx"
  },
  "fmt": {
    "lineWidth": 100,
    "singleQuote": false,
    "indentWidth": 2,
    "include": [
      "mod.tsx",
      "src/"
    ]
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    },
    "exclude": ["dist/"]
  },
  "imports": {
    "@cfworker/json-schema": "npm:@cfworker/json-schema@^2.0.1",
    "@deno/emit": "jsr:@deno/emit@^0.46.0",
    "@hono/hono": "jsr:@hono/hono",
    "@hono/hono/jsx/dom": "jsr:@hono/hono/jsx/dom",
    "@hono/hono/jsx/dom/jsx-runtime": "jsr:@hono/hono/jsx/dom/jsx-runtime",
    "@std/assert": "jsr:@std/assert@0.223.0",
    "@std/cli": "jsr:@std/cli"
  },
  "deploy": {
    "project": "b9da7955-aedb-4095-8385-fa9241d1edd5",
    "exclude": [
      "**/node_modules"
    ],
    "include": [],
    "entrypoint": "mod.tsx"
  }
}